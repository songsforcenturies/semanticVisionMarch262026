# MongoDB Connection (use MongoDB Atlas free tier)
MONGO_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=leximaster_db

# CORS - set to your frontend URL in production
CORS_ORIGINS=http://localhost:3000,https://semanticvision.ai

# JWT Secret - generate a random string: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-secret

# OpenRouter API Key (replaces Emergent LLM Key)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Email (Resend)
RESEND_API_KEY=re_your_key_here
SENDER_EMAIL=Semantic Vision <hello@semanticvision.ai>

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_your_key_here

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret

# Daily.co (Video calls)
DAILY_CO_API_KEY=your_daily_co_key

# Frontend URL (for emails, affiliate links)
FRONTEND_URL=https://semanticvision.ai
